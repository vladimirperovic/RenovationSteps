# Example environment variables for local development
PORT=3000
DATABASE_URL=file:./dev.db
ADMIN_EMAIL=admin
ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH
CLIENT_EMAIL=client
CLIENT_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH
