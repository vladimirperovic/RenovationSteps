{
  "name": "renovation-steps",
  "version": "1.2.0",
  "description": "Free self-hosted construction project management tool",
  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npx prisma generate && node server.js",
    "dev:api": "nodemon server.js",
    "dev": "nodemon server.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev --name init",
    "db:seed": "node prisma/seed_cli.js",
    "migrate:data": "node run_migration.js",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "construction",
    "project-management",
    "renovation",
    "self-hosted"
  ],
  "author": "Vladimir Perovic",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^2.2.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prisma": "^5.0.0"
  }
}